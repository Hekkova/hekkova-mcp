# ─────────────────────────────────────────────
# Hekkova MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ─── Supabase ───────────────────────────────
# Found at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─── Thirdweb / Polygon ─────────────────────
# Found at: https://thirdweb.com/dashboard → Settings → API Keys
THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key

# The deployed Hekkova ERC-721 contract on Polygon
HEKKOVA_CONTRACT_ADDRESS=0xYourContractAddressHere

# Polygon RPC endpoint (Alchemy, Infura, or public)
POLYGON_RPC_URL=https://polygon-rpc.com

# ─── Pinata (IPFS Storage) ──────────────────
# Found at: https://app.pinata.cloud → API Keys
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── Lit Protocol (Encryption) ──────────────
# Network options: cayenne, habanero, manzano
LIT_NETWORK=cayenne

# ─── Stripe (Payments) ──────────────────────
# Found at: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
